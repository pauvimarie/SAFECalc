# Copy this file to .env and fill in your real Firebase project values.
# Found in Firebase Console > Project settings > General > Your apps > SDK config.
# Note: Firebase Storage is NOT required. This app works on Spark Plan.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
